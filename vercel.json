{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": ["dist/server.cjs"]
    }
  },
  "rewrites": [
    { "source": "/api/agent/chat", "destination": "/api/agent-chat" },
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
